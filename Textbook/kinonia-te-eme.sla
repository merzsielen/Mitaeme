            <StoryText>
                <DefaultStyle/>
                <Content Chars="Like “of,” "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="te"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" can be used to indicate composition as in: “a boat (made) of wood.” In addition, this can indicate what a container is filled with."/>
