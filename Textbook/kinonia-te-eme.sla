        <PageObject XPosition="118.0008" YPosition="4004.0208" OwnPage="11" ItemID="732638070" ItemType="4" Width="360" Height="504" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L360 0 L360 504 L0 504 L0 0 Z" ContourLinePath="M0 0 L360 0 L360 504 L0 504 L0 0 Z" gXpos="118.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle/>
                <Content CParent="Header #1" FontColor="Red" FillShade="100" Chars="I – The Coordinating Conjunction"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <Content Chars="The coordinating conjunction, "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="i"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=", is used like “and” to connect nouns, phrases, and sentences."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <tab/>
                <Content Chars="Man le ale a satu-kasa "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="i"/>
                <Content Chars=" pai wino."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="man"/>
                <tab/>
                <Content Chars="le"/>
                <tab/>
                <Content Chars="ale"/>
                <tab/>
                <Content Chars="a"/>
                <tab/>
                <Content Chars="satu-kasa"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="i"/>
                <tab/>
                <Content Chars="pai"/>
                <tab/>
                <Content Chars="wino"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="I"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="pst"/>
                <tab/>
                <Content Chars="go"/>
                <tab/>
                <Content Chars="to"/>
                <tab/>
                <Content Chars="store"/>
                <tab/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="and"/>
                <tab/>
                <Content Chars="buy"/>
                <tab/>
                <Content Chars="wine"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="I went to the store and bought wine."/>
                <trail ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
            </StoryText>
        </PageObject>
