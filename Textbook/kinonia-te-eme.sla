            </StoryText>
        </PageObject>
        <PageObject XPosition="118.0008" YPosition="2700.0144" OwnPage="7" ItemID="1224547232" ItemType="4" Width="180" Height="180" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L180 0 L180 180 L0 180 L0 0 Z" ContourLinePath="M0 0 L180 0 L180 180 L0 180 L0 0 Z" gXpos="118.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Yan A:"/>
                <Content Chars=" Kai tali!"/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Yan B:"/>
                <Content Chars=" Kai tali! Ni te men ma?"/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Yan A:"/>
                <Content Chars=" Man te men Erin. I ni?"/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Yan B:"/>
                <Content Chars=" Man te men Kuancin. Ni famwen teke ma-meta?"/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Yan A:"/>
                <Content Chars=" Man teke Kalifonia. Ni katiki a ti ma?"/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Yan B:"/>
                <Content Chars=" Na, man te kasa a Peicin."/>
                <para/>
            </StoryText>
        </PageObject>
        <PageObject XPosition="298.0008" YPosition="2700.0144" OwnPage="7" ItemID="311367000" ItemType="4" Width="180" Height="180" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L180 0 L180 180 L0 180 L0 0 Z" ContourLinePath="M0 0 L180 0 L180 180 L0 180 L0 0 Z" gXpos="298.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Alignment="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle Alignment="0"/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Person A:"/>
                <Content Chars=" Hello!"/>
                <para Alignment="0"/>
                <para Alignment="0"/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Person B:"/>
                <Content Chars=" Hello! What is your name?"/>
                <para Alignment="0"/>
                <para Alignment="0"/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Person A:"/>
                <Content Chars=" My name is Erin. And you?"/>
                <para Alignment="0"/>
                <para Alignment="0"/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Person B:"/>
                <Content Chars=" My name is Guangxin. Where are you visiting from?"/>
                <para Alignment="0"/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Person A:"/>
                <Content Chars=" I am from California. Do you live here?"/>
                <para Alignment="0"/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Person B:"/>
                <Content Chars=" No, my home is in Beijing."/>
                <trail Alignment="0"/>
            </StoryText>
        </PageObject>
        <PageObject XPosition="121.6008" YPosition="2872.41440000001" OwnPage="7" ItemID="1343125487" ItemType="5" Width="352.8" Height="1" FrameType="0" ClipEdited="0" LineWidth="1.8" FillShade="0" LineColor="Black" LinePenStyle="3" Path="" gXpos="121.6008" gYpos="1568.408" gWidth="0" gHeight="0" Layer="0"/>
        <PageObject XPosition="514.0008" YPosition="2700.0144" OwnPage="8" ItemID="1832996903" ItemType="4" Width="360" Height="504" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L360 0 L360 504 L0 504 L0 0 Z" ContourLinePath="M0 0 L360 0 L360 504 L0 504 L0 0 Z" gXpos="118.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle/>
                <Content CParent="Header #1" FontColor="Red" FillShade="100" Chars="Free Parts of Speech"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="Words never change form. There are no prefixes or suffixes and no changes to roots."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="A language like English will sometimes use affixes to indicate grammatical features—we often make a noun plural in this way: “car” to “cars,” where the suffix ‘-s’ indicates the plural form. Similarly, we sometimes make changes to the root: “mouse” to “mice.” "/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="Mitaeme never does this. Instead, extra words are added to sentences to convey more complex meaning. Words may either be "/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="free"/>
                <Content Chars=", not relying on other words to appear, or "/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="bound"/>
                <Content Chars=", relying on other words. There are three basic types of free words:"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="A "/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="verb"/>
                <Content Chars=" refers to an action, occurrence, or state: “to know,” “to have,” “to understand,” and so on."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="Ta-man "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="ale"/>
                <Content Chars=" a "/>
                <Content Font="Times New Roman Regular" FontColor="Black" FillShade="100" Chars="kasa"/>
                <Content Chars="."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="ta-man"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="ale"/>
                <tab/>
                <Content Chars="a"/>
                <tab/>
                <Content Chars="kasa"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="we"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="go"/>
                <tab/>
                <Content Chars="to"/>
                <tab/>
                <Content Chars="house"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="We are going to the house."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="An "/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="adjective"/>
                <Content Chars=" refers to a quality: “green,” “blue,” “heavy,” “good,” “old,” and so on. Adjectives may also act as adverbs, when semantically applicable. Adjectives always appear directly before the word they modify."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="Ti "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="umai"/>
                <Content Chars=" kafe."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="ti"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="umai"/>
                <tab/>
                <tab/>
                <Content Chars="kafe"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="this"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="delicious"/>
                <tab/>
                <Content Chars="coffee"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="This is delicious coffee."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="A "/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="noun"/>
                <Content Chars=" refers to a person, place, thing, or concept: “woman,” “garden,” “spoon,” “beauty,” and so on. Nouns also include pronouns like “I,” “you,” and “they.”"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Ni"/>
                <Content Chars=" tinke "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="palu"/>
                <Content Chars="."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="ni"/>
                <tab/>
                <Content Chars="tinke"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="palu"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="you"/>
                <tab/>
                <Content Chars="drink"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="milk"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="You are drinking milk."/>
                <trail/>
            </StoryText>
        </PageObject>
