        <PageObject XPosition="118.0008" YPosition="1396.008" OwnPage="3" ItemID="1462481676" ItemType="4" Width="360" Height="504" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L360 0 L360 504 L0 504 L0 0 Z" ContourLinePath="M0 0 L360 0 L360 504 L0 504 L0 0 Z" gXpos="118.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle/>
                <Content Chars="Mitaeme features "/>
                <Content Font="Times New Roman Bold" FontColor="FromPDF#ed2024" Chars="twelve consonants"/>
                <Content Chars=". In this textbook, the letter used to write each consonant will be included between angle brackets, , while the pronunciation will be written in the International Phonetic Alphabet (IPA) and placed between forward slashes, /.../. For each sound, we will provide a rough example in Standard American English."/>
                <para/>
                <para/>
                <para/>
                <para/>
                <para/>
                <para/>
                <para/>
                <para/>
                <para/>
                <para/>
                <para/>
                <para/>
                <para/>
                <para/>
                <para/>
                <Content Chars="In addition to these, there are "/>
                <Content Font="Times New Roman Bold" FontColor="FromPDF#ed2024" Chars="five vowels"/>
                <Content Chars=". Two examples are given: first in Standard American English and then in Spanish, as the five vowels of Mitaeme do not align well with those in English but align perfectly with those in Spanish (or Japanese, Tamil, and so on)."/>
                <para/>
                <para/>
