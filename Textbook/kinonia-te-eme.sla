                <DefaultStyle Alignment="2" Font="Times New Roman Bold" FontSize="14" FontColor="FromPDF#ed2024"/>
                <Content Font="Times New Roman Bold" FontSize="14" FontColor="FromPDF#ed2024" Chars="OPTATIVE, PRESENT, &amp; DISJUNCTIVE"/>
