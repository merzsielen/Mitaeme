                <tab/>
                <Content Chars="person"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="They are a Spanish person."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="Man Intonesia "/>
                <Content Font="Times New Roman Bold" Features="inherit" FontColor="Blue" FillShade="100" Chars="te"/>
                <Content Chars="."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="man"/>
                <tab/>
                <Content Chars="Intonesia"/>
                <tab/>
                <Content Font="Times New Roman Bold" Features="inherit" FontColor="Blue" FillShade="100" Chars="te"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="I"/>
                <tab/>
                <Content Chars="Indonesia"/>
                <tab/>
                <Content Font="Times New Roman Bold" Features="inherit smallcaps" FontColor="Blue" FillShade="100" Chars="gen"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="I am Indonesian."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content CParent="Header #1" FontColor="Red" FillShade="100" Chars="Ma – The Interrogative Particle"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <Content Chars="Questions always contain the particle "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="ma"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=", which marks the sentence as such."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="Ma"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" may also be compounded with nouns to form question words like “what” or “how.” For example, "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="ma-meta"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" “where” sees "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="ma"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" combined with "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="meta"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" “place.” Similarly, "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="ma-aika"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" “when” sees it combined with "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="aika"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" “time.” Any noun may be combined with "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="ma"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" to form the meaning “which / what ___.” For example, "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="imahen"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" “picture” becomes "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="ma-imahen"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" “which picture.”"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <tab/>
                <Content Chars="Ni le ale a "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="ma"/>
                <Content Chars="-kasa?"/>
                <para/>
                <tab/>
                <Content Chars="ni"/>
                <tab/>
                <Content Chars="le"/>
                <tab/>
                <Content Chars="ale"/>
                <tab/>
                <Content Chars="a"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="ma"/>
                <Content Chars="-kasa"/>
                <para/>
                <tab/>
                <Content Chars="you"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="pst"/>
                <tab/>
                <Content Chars="go"/>
                <tab/>
                <Content Chars="to"/>
                <tab/>
                <Content Font="Times New Roman Bold" Features="inherit smallcaps" FontColor="Blue" FillShade="100" Chars="int"/>
                <Content Chars="-house"/>
                <para/>
                <tab/>
                <Content Chars="Which house did you go to?"/>
                <trail/>
            </StoryText>
        </PageObject>
