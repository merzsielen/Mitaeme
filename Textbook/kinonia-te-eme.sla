        <PageObject XPosition="118.0008" YPosition="3352.0176" OwnPage="9" ItemID="19023088" ItemType="4" Width="360" Height="504" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L360 0 L360 504 L0 504 L0 0 Z" ContourLinePath="M0 0 L360 0 L360 504 L0 504 L0 0 Z" gXpos="118.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle/>
                <Content CParent="Header #1" FontColor="Red" FillShade="100" Chars="Bound Parts of Speech"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <Content Chars="There are two additional parts of speech that can only appear when they are attached to another word or phrase: prepositions and particles."/>
                <para/>
                <para/>
                <Content Chars="A "/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="preposition"/>
                <Content Chars=" creates a relationship between a noun and other parts of the sentence. Usually, this relationship has to do with location, time, direction, or manner. Prepositions are words like “in,” “at,” “on,” “while,” and so on. Prepositions always appear before the noun, with other words like adjectives and possessors that modify the same noun appearing between the preposition and the modified word."/>
                <para/>
                <para/>
                <tab/>
                <Content Chars="Ta-ye ale "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="a"/>
                <Content Chars=" ca-kasa "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="teke"/>
                <Content Chars=" kasa."/>
                <para/>
                <tab/>
                <Content FontSize="10" Chars="ta-ye"/>
                <tab FontSize="10"/>
                <Content FontSize="10" Chars="ale"/>
                <tab FontSize="10"/>
                <Content Font="Times New Roman Bold" FontSize="10" FontColor="Blue" FillShade="100" Chars="a"/>
                <tab FontSize="10"/>
                <Content FontSize="10" Chars="aiki-meta"/>
                <tab FontSize="10"/>
                <Content Font="Times New Roman Bold" FontSize="10" FontColor="Blue" FillShade="100" Chars="teke"/>
                <tab FontSize="10"/>
                <Content FontSize="10" Chars="kasa"/>
                <para/>
                <tab FontSize="10"/>
                <Content FontSize="10" Chars="they (2+)"/>
                <tab FontSize="10"/>
                <Content FontSize="10" Chars="go"/>
                <tab FontSize="10"/>
                <Content Font="Times New Roman Bold" FontSize="10" FontColor="Blue" FillShade="100" Chars="to"/>
                <tab FontSize="10"/>
                <Content FontSize="10" Chars="workplace"/>
                <tab FontSize="10"/>
                <Content Font="Times New Roman Bold" FontSize="10" FontColor="Blue" FillShade="100" Chars="from"/>
                <tab FontSize="10"/>
                <Content FontSize="10" Chars="home"/>
                <para/>
                <tab/>
                <Content Chars="They are going to work from home."/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Particles"/>
                <Content Chars=" add information and connect phrases.  In Mitaeme, this includes words like “no,” “that,” “and,” as well as possessive and question markers. Particles can appear at the beginning of ends of sentences or before the verb they modify, with adverbs placed between the particle and verb."/>
                <para/>
                <para/>
                <tab/>
                <Content Chars="Ye "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="te"/>
                <Content Chars=" auto "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="le"/>
                <Content Chars=" osoi ale "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="ma"/>
                <Content Chars="?"/>
                <para/>
                <tab/>
                <Content FontSize="10" Chars="ye"/>
                <tab FontSize="10"/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="te"/>
                <tab FontSize="10"/>
                <Content FontSize="10" Chars="auto"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="le"/>
                <tab/>
                <Content Chars="osoi"/>
                <tab/>
                <Content Chars="ale"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="ma"/>
                <para/>
                <tab/>
                <Content Chars="they"/>
                <tab/>
                <Content Font="Times New Roman Bold" Features="inherit smallcaps" FontColor="Blue" FillShade="100" Chars="gen"/>
                <tab/>
                <Content Chars="car"/>
                <tab/>
                <Content Font="Times New Roman Bold" Features="inherit smallcaps" FontColor="Blue" FillShade="100" Chars="pst"/>
                <tab/>
                <Content Chars="slow"/>
                <tab/>
                <Content Chars="go"/>
                <tab/>
                <Content Font="Times New Roman Bold" Features="inherit smallcaps" FontColor="Blue" FillShade="100" Chars="int"/>
                <para/>
                <tab/>
                <Content Chars="Did their car go slowly?"/>
                <para/>
                <para/>
                <para/>
                <Content CParent="Header #1" FontColor="Red" FillShade="100" Chars="Te – The Genitive Particle"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <Content Chars="The particle, "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="te"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=", marks the “genitive”—appearing after a noun and indicating possession, origin, or composition. The possessor is the modified noun, with the possessee appearing after the particle."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <Content Chars="In English, we usually indicate the possessive meaning by writing “-’s” as in “the dog’s tail” or by using the preposition “of” as in “the house of the doctor.” In Mitaeme, this is achieved by placing "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="te"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" between the possessor and what is possessed."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="Ti man "/>
                <Content Font="Times New Roman Bold" Features="inherit" FontColor="Blue" FillShade="100" Chars="te"/>
                <Content Chars=" cota kasa."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="ti"/>
                <tab/>
                <Content Chars="man"/>
                <tab/>
                <Content Font="Times New Roman Bold" Features="inherit" FontColor="Blue" FillShade="100" Chars="te"/>
                <tab/>
                <Content Chars="cota"/>
                <tab/>
                <Content Chars="kasa"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="this"/>
                <tab/>
                <Content Chars="I"/>
                <tab/>
                <Content Font="Times New Roman Bold" Features="inherit smallcaps" FontColor="Blue" FillShade="100" Chars="gen"/>
                <tab/>
                <Content Chars="small"/>
