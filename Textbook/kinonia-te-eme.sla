        <PageObject XPosition="118.0008" YPosition="4656.024" OwnPage="13" ItemID="1173927833" ItemType="4" Width="180" Height="180" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L180 0 L180 180 L0 180 L0 0 Z" ContourLinePath="M0 0 L180 0 L180 180 L0 180 L0 0 Z" gXpos="118.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Yan A:"/>
                <Content Chars=" Koi koi! Man na iya tinke man te ca na o-ke ye sahin."/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Yan B:"/>
                <Content Chars=" A! Man ale pana palu o-ke citala-hase ye."/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Yan A:"/>
                <Content Chars=" Koi koi."/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Yan B:"/>
                <Content Chars=" Ti-so. Samaha man."/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Yan A:"/>
                <Content Chars=" Na pentin. Man ale pai keike tampien, koi koi. Ni te keike kai umai."/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Yan B:"/>
                <Content Chars=" So so. Man kome hafe ni te keike."/>
                <trail/>
            </StoryText>
        </PageObject>
        <PageObject XPosition="298.0008" YPosition="4656.024" OwnPage="13" ItemID="150554502" ItemType="4" Width="180" Height="180" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L180 0 L180 180 L0 180 L0 0 Z" ContourLinePath="M0 0 L180 0 L180 180 L0 180 L0 0 Z" gXpos="298.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Alignment="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle Alignment="0"/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Person A:"/>
                <Content Chars=" Excuse me! I cannot drink my tea because it is hot."/>
                <para Alignment="0"/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Person B:"/>
                <Content Chars=" Oh! I will go get milk in order to cool it down."/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Person A:"/>
                <Content Chars=" Thank you."/>
                <para Alignment="0"/>
                <para Alignment="0"/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Person B:"/>
                <Content Chars=" Here you go. I’m sorry."/>
                <para Alignment="0"/>
                <para Alignment="0"/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Person A:"/>
                <Content Chars=" It’s nothing. I will also buy cake, please. Your cake is very tasty."/>
                <para Alignment="0"/>
                <para Alignment="0"/>
                <Content Chars=" "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Person B:"/>
                <Content Chars=" Of course. I’ll bring your cake."/>
                <para Alignment="0"/>
            </StoryText>
        </PageObject>
