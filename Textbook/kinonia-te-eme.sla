        <PageObject XPosition="121.6008" YPosition="4833.42400000001" OwnPage="13" ItemID="919052516" ItemType="5" Width="352.8" Height="1" FrameType="0" ClipEdited="0" LineWidth="1.8" FillShade="0" LineColor="Black" LinePenStyle="3" Path="" gXpos="121.6008" gYpos="1573.408" gWidth="0" gHeight="0" Layer="0"/>
        <PageObject XPosition="130.2408" YPosition="4855.124" OwnPage="13" ItemID="1483820858" ItemType="5" Width="335.16" Height="1" FrameType="0" ClipEdited="0" LineWidth="1.8" LineColor="Black" LinePenStyle="1" Path="" gXpos="526.2408" gYpos="1595.108" gWidth="0" gHeight="0" Layer="0"/>
        <PageObject XPosition="514.0008" YPosition="4656.024" OwnPage="14" ItemID="1247165315" ItemType="4" Width="360" Height="504" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L360 0 L360 504 L0 504 L0 0 Z" ContourLinePath="M0 0 L360 0 L360 504 L0 504 L0 0 Z" gXpos="118.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle/>
                <Content CParent="Header #1" FontColor="Red" FillShade="100" Chars="The Subject"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <Content Chars="Every sentence has at least two parts: the "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="subject"/>
                <Content Chars=" and the "/>
                <Content Font="Times New Roman Regular" FontColor="Black" FillShade="100" Chars="verb"/>
                <Content Chars=". The subject is the noun about which the statement is made and is usually the one performing the verb. The subject always comes before the verb, though it may be elided if it is obvious given context. The subject is not marked by a particle or preposition."/>
                <para/>
                <para/>
                <Content Chars="The passive particle, "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="pei"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=", makes it so that the semantic object is elevated to the position of the grammatical subject. In simpler terms, this means that the old subject is dropped (or included with the preposition, "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="pa"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" “by”) and the old object is moved up to replace the it, making it the new subject."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Man"/>
                <Content Chars=" le ci pala a kasa."/>
                <para/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="man"/>
                <tab/>
                <Content Chars="le"/>
                <tab/>
                <Content Chars="ci"/>
                <tab/>
                <Content Chars="pala"/>
                <tab/>
                <Content Chars="a"/>
                <tab/>
                <Content Chars="kasa"/>
                <para/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="I"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="pst"/>
                <tab/>
                <Content Chars="eat"/>
                <tab/>
                <Content Chars="fruit"/>
                <tab/>
                <Content Chars="at"/>
                <tab/>
                <Content Chars="home"/>
                <para/>
                <tab/>
                <Content Chars="I ate fruit at home."/>
                <para/>
                <para/>
                <tab/>
                <Content Chars="A kasa, "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="pala"/>
                <Content Chars=" le pei ci pa man."/>
                <para/>
                <tab/>
                <Content Chars="a"/>
                <tab/>
                <Content Chars="kasa"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="pala"/>
                <tab/>
                <Content Chars="le"/>
                <tab/>
                <Content Chars="pei"/>
                <tab/>
                <Content Chars="ci"/>
                <tab/>
                <Content Chars="pa"/>
                <tab/>
                <Content Chars="man"/>
                <para/>
                <tab/>
                <Content Chars="at"/>
                <tab/>
                <Content Chars="home"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="fruit"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="pst"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="pv"/>
                <tab/>
                <Content Chars="eat"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="instr"/>
                <tab/>
                <Content Chars="I"/>
                <para/>
                <tab/>
                <Content Chars="At home, fruit was eaten by me."/>
                <para/>
                <tab/>
                <para/>
                <para/>
                <Content CParent="Header #1" FontColor="Red" FillShade="100" Chars="The Object"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <Content Chars="Certain verbs require an object: the noun which the verb is being done to. These always follow the verb. The object is also known as the “direct object,” in contrast to the “indirect object.” The object, like the subject, is not marked by a particle or preposition."/>
                <para/>
                <para/>
                <Content Chars="As stated above, the object may replace the subject by modifying the verb with the passive particle, "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="pei"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars="."/>
