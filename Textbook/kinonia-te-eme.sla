        <PageObject XPosition="118.0008" YPosition="5960.0304" OwnPage="17" ItemID="714204898" ItemType="4" Width="180" Height="216.000000000001" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L180 0 L180 216 L0 216 L0 0 Z" ContourLinePath="M0 0 L180 0 L180 216 L0 216 L0 0 Z" gXpos="118.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Yan A:"/>
                <Content Chars=" Man tei kome hafe keike."/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Yan B:"/>
                <Content Chars=" Ni mei usa yena naife kate keike."/>
                <para/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Yan A:"/>
                <Content Chars=" Man iya usa ti! Ti osa o ni. Ti osa o ye. I ti osa o man. Ta-yan hafe keike ma?"/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Yan B:"/>
                <Content Chars=" Umai ne? Ni sahi patai ti ma? Au ni le pai ye?"/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Yan A:"/>
                <Content Chars=" Ti tu hannu sahi patai yena keike ke ni ci."/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Yan B:"/>
                <Content Chars=" Ala-tei, ni ale sita sikana patai ti a man ma?"/>
                <trail/>
            </StoryText>
        </PageObject>
        <PageObject XPosition="298.0008" YPosition="5960.0304" OwnPage="17" ItemID="1947721518" ItemType="4" Width="180" Height="216.000000000001" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L180 0 L180 216 L0 216 L0 0 Z" ContourLinePath="M0 0 L180 0 L180 216 L0 216 L0 0 Z" gXpos="298.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Alignment="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle Alignment="0"/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Person A:"/>
                <Content Chars=" I’m bringing the cake now."/>
                <para Alignment="0"/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Person B:"/>
                <Content Chars=" Why don’t you use that knife to cut the cake?"/>
                <para Alignment="0"/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Person A:"/>
                <Content Chars=" I can use this one. This pieces is for you. This piece is for them. And this piece is for me. Everyone has cake?"/>
                <para Alignment="0"/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Person B:"/>
                <Content Chars=" This is delicious, right? You really made this? Or did you buy it?"/>
                <para Alignment="0"/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Person A:"/>
                <Content Chars=" These two hands really made that cake you’re eating."/>
                <para Alignment="0"/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Person B:"/>
                <Content Chars=" Will you sit and teach me how to make this tomorrow?"/>
                <trail Alignment="0"/>
            </StoryText>
        </PageObject>
