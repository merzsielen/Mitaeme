        <PageObject XPosition="118.0008" YPosition="3204.0144" OwnPage="7" ItemID="753456951" ItemType="4" Width="18" Height="18" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="0" TextToFrameDistanceTop="0" TextToFrameDistanceBottom="0" TextToFrameDistanceRight="0" VerticalAlignment="1" FirstLineOffset="0" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L18 0 L18 18 L0 18 L0 0 Z" ContourLinePath="M0 0 L18 0 L18 18 L0 18 L0 0 Z" gXpos="118.0008" gYpos="3204.0144" gWidth="0" gHeight="0" Alignment="1" Layer="0" NextItem="-1" BackItem="-1">
