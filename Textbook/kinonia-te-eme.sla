        <PageObject XPosition="118.0008" YPosition="2048.0112" OwnPage="5" ItemID="1961462636" ItemType="4" Width="360" Height="504" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L360 0 L360 504 L0 504 L0 0 Z" ContourLinePath="M0 0 L360 0 L360 504 L0 504 L0 0 Z" gXpos="118.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle/>
                <Content Chars="Mitaeme features "/>
                <Content Font="Times New Roman Bold" FontColor="FromPDF#ed2024" Chars="seventeen"/>
                <Content Chars=" unique sounds. However, instead of going one-by-one through these, we are going to lay out the four parts of a syllable and the different sounds that can appear in each. These parts include: twelve "/>
                <Content Font="Times New Roman Bold" Features="inherit" FontColor="FromPDF#ed2024" Chars="initials"/>
                <Content Chars=" (ω), two "/>
                <Content Font="Times New Roman Bold" Features="inherit" FontColor="FromPDF#ed2024" Chars="medials"/>
                <Content Chars=" (μ), five "/>
                <Content Font="Times New Roman Bold" Features="inherit" FontColor="FromPDF#ed2024" Chars="vowels"/>
                <Content Chars=" (ν), and one "/>
                <Content Font="Times New Roman Bold" Features="inherit" FontColor="FromPDF#ed2024" Chars="final"/>
                <Content Chars=" (κ)."/>
                <para/>
                <para/>
                <Content Chars="The syllable in Mitaeme is structured like so:"/>
                <para/>
                <para/>
                <para/>
                <para/>
                <para/>
                <para/>
                <para/>
                <para/>
                <Content Chars="Importantly, there are a few restrictions on syllable structure which narrow down the number of possibilities:"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="1" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="1" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="The first medial may only appear when there is an initial, but it cannot appear when that initial is "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="y"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" or "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="w"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=". So "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="kia"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" but never *"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="yia"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars="."/>
                <breakline/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="1" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="The same letter may never appear twice, next to each other, in the same syllable. In other words, neither the first nor second medial can be "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="i"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" when the vowel is "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="i"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=". Similarly, neither medial can be "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="u"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" when the vowel is "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="u"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=". So, "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="kia"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" but never *"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="kii"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" , and "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="kua"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" but never *"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="kuu"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars="."/>
                <breakline/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="1" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="If there is a first medial, the syllable may only have a second medial or a final, never both. So "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="kiau"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" or "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="kian"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" but never *"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="kiaun"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars="."/>
                <breakline/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="1" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="The sequences "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="iu"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" and "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="ui"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" always represent a medial followed by vowel, never a vowel followed by a medial."/>
                <breakline/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="1" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="Before "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="m"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=", "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="p"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=", and "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="w"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=", the final is "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="n"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" written and pronounced as "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="m"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=". So "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="kompu"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" but never *"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="konpu"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=". Similarly, the final "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="n"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" is pronounced like the ‘ng’ in “sing” when it appears before "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="k"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=", but its spelling remains the same."/>
                <breakline/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="1" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="Lastly, a non-compound word cannot contain a syllable ending in a vowel followed by a syllable beginning with a vowel. So, "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="kahe"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" but never *"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="kae"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars="."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="1" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <Content Chars="Altogether, these rules mean that the total number of possible syllables in Mitaeme is around "/>
                <Content Font="Times New Roman Bold" FontColor="FromPDF#ed2024" Chars="462"/>
                <Content Chars=" and each syllable is never more than "/>
                <Content Font="Times New Roman Bold" FontColor="FromPDF#ed2024" Chars="4"/>
                <Content Chars=" sounds long. In addition, the spelling of a word is never ambiguous: you always know how to pronounce a word given its spelling and vice versa."/>
                <trail/>
            </StoryText>
        </PageObject>
        <PageObject XPosition="136.0008" YPosition="2138.0112" OwnPage="5" ItemID="1390231700" ItemType="16" Width="324" Height="54.5" FrameType="0" ClipEdited="0" LineWidth="0" FillShade="0" LineShade="0" LinePenStyle="1" Rows="3" Columns="5" RowPositions="0 18 36.1636" RowHeights="18 18.1636 18.3364" ColumnPositions="0 107.833 162 216.167 270" ColumnWidths="107.833 54.1672 54.1672 53.8328 54" CellAreas="" TableStyle="" Path="M0 0 L324 0 L324 54.5 L0 54.5 L0 0 Z" ContourLinePath="M0 0 L324 0 L324 54.5 L0 54.5 L0 0 Z" gXpos="136.0008" gYpos="2138.0112" gWidth="0" gHeight="0" Layer="0">
