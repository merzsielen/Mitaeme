        <PageObject XPosition="118.0008" YPosition="5308.0272" OwnPage="15" ItemID="917319580" ItemType="4" Width="360" Height="504" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L360 0 L360 504 L0 504 L0 0 Z" ContourLinePath="M0 0 L360 0 L360 504 L0 504 L0 0 Z" gXpos="118.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle/>
                <Content CParent="Header #1" FontColor="Red" FillShade="100" Chars="The Indirect Object"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="Some verbs—such as “to give”—allow an indirect object: the noun which is the recipient of the action. In Mitaeme, the indirect object is marked by the preposition, "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="a"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" “at / to.”"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="Ni te mita le tewa tinke-wa "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="a ni"/>
                <Content Chars="."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="ni"/>
                <tab/>
                <Content Chars="te"/>
                <tab/>
                <Content Chars="mita"/>
                <tab/>
                <Content Chars="le"/>
                <tab/>
                <Content Chars="tewa"/>
                <tab/>
                <Content Chars="tinke-wa"/>
                <tab/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="a"/>
                <tab Font="Times New Roman Bold" FontColor="Blue" FillShade="100"/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="ni"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="you"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="gen"/>
                <tab/>
                <Content Chars="friend"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="pst"/>
                <tab/>
                <Content Chars="give"/>
                <tab/>
                <Content Chars="drink"/>
                <tab/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="to"/>
                <tab Font="Times New Roman Bold" FontColor="Blue" FillShade="100"/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="you"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="Your friend gave the drink to you."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content CParent="Header #1" FontColor="Red" FillShade="100" Chars="Word Order"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <Content Chars="The word order of Mitaeme is SVO, or subject-verb-object. If there is an indirect object, it comes after the direct object."/>
                <para/>
                <para/>
                <Content Chars="Commands are formed by dropping the subject so that the word order becomes VO, as in:"/>
                <para/>
                <tab/>
                <para/>
                <tab/>
                <Content Chars="Ale a kasa!"/>
                <para/>
                <tab/>
                <Content Chars="ale"/>
                <tab/>
                <Content Chars="a"/>
                <tab/>
                <Content Chars="kasa"/>
                <para/>
                <tab/>
                <Content Chars="go"/>
                <tab/>
                <Content Chars="to"/>
                <tab/>
                <Content Chars="home"/>
                <para/>
                <tab/>
                <Content Chars="Go home!"/>
                <para/>
                <para/>
                <tab/>
                <Content Chars="Ci ni te ci-wa."/>
                <para/>
                <tab/>
                <Content Chars="ci"/>
                <tab/>
                <Content Chars="ni"/>
                <tab/>
                <Content Chars="te"/>
                <tab/>
                <Content Chars="ci-wa"/>
                <para/>
                <tab/>
                <Content Chars="eat"/>
                <tab/>
                <Content Chars="you"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="gen"/>
                <tab/>
                <Content Chars="food"/>
                <para/>
                <tab/>
                <Content Chars="Eat your food!"/>
                <para/>
                <para/>
                <Content Chars="As Mitaeme does not have a copula—“to be”—the general way to create such a construction is simply to use an SO word order, as in:"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <tab/>
                <Content Chars="Yena yan leka-cia."/>
                <para/>
                <tab/>
                <Content Chars="yena"/>
                <tab/>
                <Content Chars="yan"/>
                <tab/>
                <Content Chars="leka-cia"/>
                <para/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="medi"/>
                <tab/>
                <Content Chars="person"/>
                <tab/>
                <Content Chars="author"/>
                <para/>
                <tab/>
                <Content Chars="That person is an author."/>
                <trail/>
            </StoryText>
        </PageObject>
