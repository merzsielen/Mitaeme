        </PageObject>
        <PageObject XPosition="118.0008" YPosition="6612.0336" OwnPage="19" ItemID="1968006492" ItemType="4" Width="360" Height="504" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L360 0 L360 504 L0 504 L0 0 Z" ContourLinePath="M0 0 L360 0 L360 504 L0 504 L0 0 Z" gXpos="118.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle/>
                <Content CParent="Header #1" FontColor="Red" FillShade="100" Chars="Mei – The Optative Particle"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="The particle, "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="mei"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=", marks the “optative”—essentially, it indicates when the speaker wishes that the action would occur. The phrase “Long Live the Revolution!” is an optative phrase expressing the speaker’s hope for a long-lived revolution, as is “God grant me strength!” Another way to express the optative in English is “may,” as in: “may he see the error of his ways.”"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <tab/>
                <Content Chars="Ye mei kiakia leka puka."/>
                <para/>
                <tab/>
                <Content Chars="ye"/>
                <tab/>
                <Content Chars="mei"/>
                <tab/>
                <Content Chars="kiakia"/>
                <tab/>
                <Content Chars="leka"/>
                <tab/>
                <Content Chars="puka"/>
                <para/>
                <tab/>
                <Content Chars="she"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="opt"/>
                <tab/>
                <Content Chars="quick"/>
                <tab/>
                <Content Chars="write"/>
                <tab/>
                <Content Chars="book"/>
                <para/>
                <tab/>
                <Content Chars="May she write the book quickly."/>
                <para/>
                <para/>
                <Content Chars="This particle also serves much the same function as English “let’s” as in  “let’s go to the store.” In other words, it is used for encouragement or weak command. In linguistics, this is known as the hortative ("/>
                <Content Features="inherit smallcaps" Chars="hort"/>
                <Content Chars=")."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="Ni mei na hatie sita yena."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="ni"/>
                <tab/>
                <Content Chars="mei"/>
                <tab/>
                <Content Chars="na"/>
                <tab/>
                <Content Chars="hatie"/>
                <tab/>
                <Content Chars="sita"/>
                <tab/>
                <Content Chars="yena"/>
                <para/>
                <tab/>
                <Content Chars="you"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="hort"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="neg"/>
                <tab/>
                <Content Chars="want"/>
                <tab/>
                <Content Chars="sit"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="medi"/>
                <para/>
                <tab/>
                <Content Chars="You may not want to sit there."/>
                <para/>
                <para/>
                <para/>
                <Content CParent="Header #1" FontColor="Red" FillShade="100" Chars="Tei – The Present Continuous Particle"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="The particle, "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Chars="tei"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=", marks the explicit “present continuous.” Usually, you don’t need to add any extra words to indicate that an action is occurring in the present or that it is ongoing: this is conveyed through context. However, in cases where you do need to explicitly signal that an action is ongoing at the moment, you use this particle."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <tab/>
                <Content Chars="Man tei ale a kasa."/>
                <para/>
                <tab/>
                <Content Chars="man"/>
                <tab/>
                <Content Chars="tei"/>
                <tab/>
                <Content Chars="ale"/>
                <tab/>
                <Content Chars="a"/>
                <tab/>
                <Content Chars="kasa"/>
                <para/>
                <tab/>
                <Content Chars="I"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="cont"/>
                <tab/>
                <Content Chars="go"/>
                <tab/>
                <Content Chars="to"/>
                <tab/>
                <Content Chars="home"/>
                <para/>
                <tab/>
                <Content Chars="I am going home (right now)."/>
                <para/>
                <para/>
            </StoryText>
        </PageObject>
