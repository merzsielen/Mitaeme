        <PageObject XPosition="514.0008" YPosition="5960.0304" OwnPage="18" ItemID="1643871741" ItemType="4" Width="360" Height="504" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L360 0 L360 504 L0 504 L0 0 Z" ContourLinePath="M0 0 L360 0 L360 504 L0 504 L0 0 Z" gXpos="118.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle/>
                <Content CParent="Header #1" FontColor="Red" FillShade="100" Chars="Verb Chains"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <Content Chars="Verb chains, known formally as serial verb constructions, are when verbs are placed one after another in order to convey a complex series of events."/>
                <para/>
                <para/>
                <tab/>
                <Content Chars="Ta-man tei ale sita kan kino."/>
                <para/>
                <tab/>
                <Content Chars="ta-man"/>
                <tab/>
                <Content Chars="tei"/>
                <tab/>
                <Content Chars="ale"/>
                <tab/>
                <Content Chars="sita"/>
                <tab/>
                <Content Chars="kan"/>
                <tab/>
                <Content Chars="kino"/>
                <para/>
                <tab/>
                <Content Chars="we"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="cont"/>
                <tab/>
                <Content Chars="walk"/>
                <tab/>
                <Content Chars="sit"/>
                <tab/>
                <Content Chars="watch"/>
                <tab/>
                <Content Chars="movie"/>
                <para/>
                <tab/>
                <Content Chars="We are walking to go sit and watch a movie."/>
                <para/>
                <para/>
                <tab/>
                <Content Chars="Man le hoisi pau takoi ye."/>
                <para/>
                <tab/>
                <Content Chars="man"/>
                <tab/>
                <Content Chars="le"/>
                <tab/>
                <Content Chars="hoisi"/>
                <tab/>
                <Content Chars="pau"/>
                <tab/>
                <Content Chars="takoi"/>
                <tab/>
                <Content Chars="ye"/>
                <para/>
                <tab/>
                <Content Chars="I"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="pst"/>
                <tab/>
                <Content Chars="start"/>
                <tab/>
                <Content Chars="run"/>
                <tab/>
                <Content Chars="meet"/>
                <tab/>
                <Content Chars="they"/>
                <para/>
                <tab/>
                <Content Chars="I started to run to meet them."/>
                <para/>
                <para/>
                <Content Chars="Sometimes, verb chains are used to convey a single event, as in:"/>
                <para/>
                <para/>
                <tab/>
                <Content Chars="Man le kome hafe saikale."/>
                <para/>
                <tab/>
                <Content Chars="man"/>
                <tab/>
                <Content Chars="le"/>
                <tab/>
                <Content Chars="kome"/>
                <tab/>
                <Content Chars="hafe"/>
                <tab/>
                <Content Chars="saikale"/>
                <para/>
                <tab/>
                <Content Chars="I"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="pst"/>
                <tab/>
                <Content Chars="come"/>
                <tab/>
                <Content Chars="have"/>
                <tab/>
                <Content Chars="bicycle"/>
                <para/>
                <tab/>
                <Content Chars="I brought a bike."/>
                <para/>
                <para/>
                <Content Chars="When an object comes after one verb and before another, it serves as either the subject or the instrument, tool, or means of achieving the subsequent verb, as in:"/>
                <para/>
                <para/>
                <tab/>
                <Content Chars="Usa mi te fon cian ni te mama."/>
                <para/>
                <tab/>
                <Content Chars="usa"/>
                <tab/>
                <Content Chars="mi"/>
                <tab/>
                <Content Chars="te"/>
                <tab/>
                <Content Chars="fon"/>
                <tab/>
                <Content Chars="cian"/>
                <tab/>
                <Content Chars="ni"/>
                <tab/>
                <Content Chars="te"/>
                <tab/>
                <Content Chars="mama"/>
                <para/>
                <tab/>
                <Content Chars="use"/>
                <tab/>
                <Content Chars="I"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="gen"/>
                <tab/>
                <Content Chars="phone"/>
                <tab/>
                <Content Chars="speak"/>
                <tab/>
                <Content Chars="you"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="gen"/>
                <tab/>
                <Content Chars="mother"/>
                <para/>
                <tab/>
                <Content Chars="Use my phone to talk to your mom."/>
                <para/>
                <para/>
                <tab/>
                <Content Chars="Laki le kome hafe puka leka a kafe-kasa."/>
                <para/>
                <tab/>
                <Content Chars="laki"/>
                <tab/>
                <Content Chars="le"/>
                <tab/>
                <Content Chars="kome"/>
                <tab/>
                <Content Chars="hafe"/>
                <tab/>
                <Content Chars="puka"/>
                <tab/>
                <Content Chars="leka"/>
                <tab/>
                <Content Chars="a"/>
                <tab/>
                <Content Chars="kafe-kasa"/>
                <para/>
                <tab/>
                <Content Chars="man"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="pst"/>
                <tab/>
                <Content Chars="come"/>
                <tab/>
                <Content Chars="have"/>
                <tab/>
                <Content Chars="book"/>
                <tab/>
                <Content Chars="read"/>
                <tab/>
                <Content Chars="at"/>
                <tab/>
                <Content Chars="cafe"/>
                <para/>
                <tab/>
                <Content Chars="The man brought the book to read at the cafe."/>
                <para/>
                <para/>
                <Content Chars="When a particle modifies a particular verb in a verb chain (rather than modifying the whole series of verbs), it must come directly before it."/>
                <trail/>
            </StoryText>
