        </PageObject>
        <PageObject XPosition="514.0008" YPosition="1342.008" OwnPage="4" ItemID="285207722" ItemType="4" Width="198" Height="36" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="0" TextToFrameDistanceBottom="0" TextToFrameDistanceRight="0" VerticalAlignment="1" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L198 0 L198 36 L0 36 L0 0 Z" ContourLinePath="M0 0 L198 0 L198 36 L0 36 L0 0 Z" gXpos="118.0008" gYpos="1994.0112" gWidth="0" gHeight="0" Alignment="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle Alignment="0" Font="Times New Roman Bold" FontSize="14" FontColor="Red" FillShade="100"/>
                <Content Font="Times New Roman Bold" FontSize="14" FontColor="Red" FillShade="100" Chars="SPELLING"/>
                <trail Alignment="0"/>
            </StoryText>
        </PageObject>
        <PageObject XPosition="514.0008" YPosition="1396.008" OwnPage="4" ItemID="1859521699" ItemType="4" Width="360" Height="504" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L360 0 L360 504 L0 504 L0 0 Z" ContourLinePath="M0 0 L360 0 L360 504 L0 504 L0 0 Z" gXpos="118.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle/>
                <Content Chars="All sounds in Mitaeme are written with exactly one letter, and each letter is only ever pronounced exactly one way—with the slight exception of /j/ and /w/."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <Content Chars="In a syllable, when /j/ or /w/ appear after a consonant or vowel, they are written "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="i"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" and "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="u"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" respectively. Thus, /koj/ is written "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="koi"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" and /t͡ʃjaw/ is written "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="ciau"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars="."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="However, across syllables, this rule does not apply, so /an.ja/ is written "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="anya"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" instead of *"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="ania"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars="."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="This helps the reader distinguish between"/>
                <Content Font="Segoe UI Symbol Regular" Chars=" ⟨"/>
                <Content Font="Times New Roman Regular" Chars="anya"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" /an.ja/ and "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="ania"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" /a.nja/ which would otherwise both be written the same. This becomes important for recognizing the different parts of compound words."/>
                <para/>
                <para/>
                <Content Chars="Finally, /n/ is written "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="m"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" and pronounced as /m/ whenever it appears before /m/, /p/, or /w/. Thus, you can have a word like "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="kompiuta"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" /kom.pju.ta/ but never *"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="konpiuta"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars="."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <para/>
                <Content CParent="Header #1" FontColor="Red" FillShade="100" Chars="The R-Sound"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="Mitaeme features one extra sound that, as a rule, never appears in general vocabulary. It is only ever used for proper names of people, places, cultures, etc. This sound is "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="r"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" /ɾ/ which is pronounced like the ‘r’ in Spanish “pero” or, in most American English dialects, the ‘tt’ in “butter.”"/>
                <para/>
                <para/>
                <Content Chars="This sound only exists so that Mitaeme can borrow words like "/>
                <Content Font="Noto Sans Devanagari Regular" Chars="मराठी"/>
                <Content Chars=" (marāṭhī) as "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="Marati"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" and Росси́я (Rossíja) as "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="Rasiya"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars="."/>
                <para/>
                <para/>
                <para/>
                <Content CParent="Header #1" FontColor="Red" FillShade="100" Chars="Punctuation"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content Chars="The first letter of each sentence is capitalized: "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="M N P T C K F S H W L Y R"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=" and "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="I E A U O"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=". In addition, proper names may be capitalized."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <Content Chars="The period, "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨.⟩"/>
                <Content Chars=", is used at the end of sentences. The exclamation mark, "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨!⟩"/>
                <Content Chars=", may be used for exclamatory phrases and interjections! And the question mark, "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨?⟩"/>
                <Content Chars=", is used at the end of questions."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <Content Chars="Finally, the hyphen, "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨-⟩"/>
                <Content Chars=", is used between the different parts of a compound word. When a word is common and relatively unambiguous, the hyphen may be dropped, as in "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="motosaikale"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars=", “motorcycle.” Conversely, some highly-frequent adjective-noun pairs such as the pronoun, "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="ta ni"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩ "/>
                <Content Chars="“y’all,” may appear hyphenated: "/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟨"/>
                <Content Font="Times New Roman Regular" Chars="ta-ni"/>
                <Content Font="Segoe UI Symbol Regular" Chars="⟩"/>
                <Content Chars="."/>
                <trail ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
            </StoryText>
        </PageObject>
        <PageObject XPosition="517.6008" YPosition="1618.408" OwnPage="4" ItemID="1626699754" ItemType="5" Width="352.8" Height="1" FrameType="0" ClipEdited="0" LineWidth="1.8" LineColor="Red" LinePenStyle="1" Path="" gXpos="517.6008" gYpos="1618.408" gWidth="0" gHeight="0" Layer="0"/>
