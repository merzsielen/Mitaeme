            <StoryText>
                <DefaultStyle Alignment="2" Font="Times New Roman Bold" FontSize="14" FontColor="Red" FillShade="100"/>
                <Content Font="Times New Roman Bold" FontSize="14" FontColor="Red" FillShade="100" Chars="CONSONANTS &amp; VOWELS"/>
                <trail Alignment="2"/>
