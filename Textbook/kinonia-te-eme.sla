        <PageObject XPosition="514.0008" YPosition="2646.0144" OwnPage="8" ItemID="30041334" ItemType="4" Width="198" Height="36" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="0" TextToFrameDistanceBottom="0" TextToFrameDistanceRight="0" VerticalAlignment="1" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L198 0 L198 36 L0 36 L0 0 Z" ContourLinePath="M0 0 L198 0 L198 36 L0 36 L0 0 Z" gXpos="118.0008" gYpos="1994.0112" gWidth="0" gHeight="0" Alignment="0" Layer="0" NextItem="-1" BackItem="-1">
