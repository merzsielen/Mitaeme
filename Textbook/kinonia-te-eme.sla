        <PageObject XPosition="118.0008" YPosition="2880.0144" OwnPage="7" ItemID="838886076" ItemType="4" Width="360" Height="324" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L360 0 L360 324 L0 324 L0 0 Z" ContourLinePath="M0 0 L360 0 L360 324 L0 324 L0 0 Z" gXpos="118.0008" gYpos="2228.0112" gWidth="0" gHeight="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle/>
                <Content CParent="Header #1" FontColor="Red" FillShade="100" Chars="Independent Parts of Speech"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <Content Chars="Words never change form. There are no prefixes or suffixes and no changes to roots."/>
                <para/>
                <para/>
                <Content Chars="A language like English will sometimes use affixes to indicate grammatical features—we often make a noun plural in this way: “car” to “cars,” where the suffix ‘-s’ indicates the plural form. Similarly, we sometimes make changes to the root: “mouse” to “mice.” "/>
                <para/>
                <Content Chars="Mitaeme never does this. Instead, extra words are added to sentences to convey more complex meaning. There are 3 basic types of words, or “parts of speech”: verbs, adjectives, and nouns."/>
                <para/>
                <para/>
                <Content Chars="A "/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="verb"/>
                <Content Chars=" refers to an action, occurrence, or state: “to know,” “to have,” “to understand,” and so on."/>
                <para/>
                <para/>
                <tab/>
                <Content Chars="Ta-man "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="ale"/>
                <Content Chars=" a "/>
                <Content Font="Times New Roman Regular" FontColor="Black" FillShade="100" Chars="kasa"/>
                <Content Chars="."/>
                <para/>
                <tab/>
                <Content Chars="ta-man"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="ale"/>
                <tab/>
                <Content Chars="a"/>
                <tab/>
                <Content Chars="kasa"/>
                <para/>
                <tab/>
                <Content Chars="we"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="go"/>
                <tab/>
                <Content Chars="to"/>
                <tab/>
                <Content Chars="house"/>
                <para/>
                <tab/>
                <Content Chars="We are going to the house."/>
                <para/>
                <para/>
                <Content Chars="An "/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="adjective"/>
                <Content Chars=" refers to a quality: “green,” “blue,” “heavy,” “good,” “old,” and so on."/>
                <para/>
                <para/>
                <tab/>
                <Content Chars="Ti "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="umai"/>
                <Content Chars=" kafe."/>
                <para/>
                <tab/>
                <Content Chars="ti"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="umai"/>
                <tab/>
                <tab/>
                <Content Chars="kafe"/>
                <para/>
                <tab/>
                <Content Chars="this"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="delicious"/>
                <tab/>
                <Content Chars="coffee"/>
                <para/>
                <tab/>
                <Content Chars="This is delicious coffee."/>
                <para/>
            </StoryText>
        </PageObject>
        <PageObject XPosition="118.0008" YPosition="2700.0144" OwnPage="7" ItemID="1160166513" ItemType="4" Width="180" Height="180" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L180 0 L180 180 L0 180 L0 0 Z" ContourLinePath="M0 0 L180 0 L180 180 L0 180 L0 0 Z" gXpos="118.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Yan A:"/>
                <Content Chars=" Kai tali!"/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Yan B:"/>
                <Content Chars=" Kai tali! Ni te men ma?"/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Yan A:"/>
                <Content Chars=" Man te men Erin. I ni?"/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Yan B:"/>
                <Content Chars=" Man te men Kuancin. Ni famwen teke ma-meta?"/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Yan A:"/>
                <Content Chars=" Man teke Kalifonia. Ni katiki a ti ma?"/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Yan B:"/>
                <Content Chars=" Na, man te kasa a Peicin."/>
                <para/>
            </StoryText>
        </PageObject>
        <PageObject XPosition="298.0008" YPosition="2700.0144" OwnPage="7" ItemID="96992973" ItemType="4" Width="180" Height="180" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L180 0 L180 180 L0 180 L0 0 Z" ContourLinePath="M0 0 L180 0 L180 180 L0 180 L0 0 Z" gXpos="298.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Alignment="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle Alignment="0"/>
                <Content FontColor="Red" FillShade="100" Chars="Person A:"/>
                <Content Chars=" Hello!"/>
                <para Alignment="0"/>
                <para Alignment="0"/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Person B:"/>
                <Content Chars=" Hello! What is your name?"/>
                <para Alignment="0"/>
                <para Alignment="0"/>
                <Content FontColor="Red" FillShade="100" Chars="Person A:"/>
                <Content Chars=" My name is Erin. And you?"/>
                <para Alignment="0"/>
                <para Alignment="0"/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Person B:"/>
                <Content Chars=" My name is Guangxin. Where are you visiting from?"/>
                <para Alignment="0"/>
                <para/>
                <Content FontColor="Red" FillShade="100" Chars="Person A:"/>
                <Content Chars=" I am from California. Do you live here?"/>
                <para Alignment="0"/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Person B:"/>
                <Content Chars=" No, my home is in Beijing."/>
                <trail Alignment="0"/>
            </StoryText>
        </PageObject>
        <PageObject XPosition="121.6008" YPosition="2872.41440000001" OwnPage="7" ItemID="1619428141" ItemType="5" Width="352.8" Height="1" FrameType="0" ClipEdited="0" LineWidth="1.8" FillShade="0" LineColor="Black" LinePenStyle="3" Path="" gXpos="121.6008" gYpos="1568.408" gWidth="0" gHeight="0" Layer="0"/>
        <PageObject XPosition="121.6008" YPosition="2902.6144" OwnPage="7" ItemID="205999373" ItemType="5" Width="352.8" Height="1" FrameType="0" ClipEdited="0" LineWidth="1.8" LineColor="Red" LinePenStyle="1" Path="" gXpos="517.6008" gYpos="1598.608" gWidth="0" gHeight="0" Layer="0"/>
        <PageObject XPosition="514.0008" YPosition="2700.0144" OwnPage="8" ItemID="167539630" ItemType="4" Width="360" Height="504" FrameType="0" ClipEdited="0" LineWidth="1" LinePenStyle="1" ImageScaleX="1" ImageScaleY="1" ImageOffsetX="0" ImageOffsetY="0" ImageRotation="0" ImageVisible="1" ImageScaleType="1" ImageRatio="1" Columns="1" ColumnGap="3.6" AutomaticTextFrame="0" TextToFrameDistanceLeft="3.6" TextToFrameDistanceTop="3.6" TextToFrameDistanceBottom="3.6" TextToFrameDistanceRight="3.6" VerticalAlignment="0" FirstLineOffset="1" PathTextShowPath="0" PathTextDistanceFromPath="0" TextPathType="0" TextPathFlipped="0" Path="M0 0 L360 0 L360 504 L0 504 L0 0 Z" ContourLinePath="M0 0 L360 0 L360 504 L0 504 L0 0 Z" gXpos="118.0008" gYpos="2048.0112" gWidth="0" gHeight="0" Layer="0" NextItem="-1" BackItem="-1">
            <StoryText>
                <DefaultStyle/>
                <Content Chars="A "/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="noun"/>
                <Content Chars=" refers to a person, place, thing, or concept: “woman,” “garden,” “spoon,” “beauty,” and so on. Nouns also include pronouns like “I,” “you,” and “they.”"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="Ni"/>
                <Content Chars=" le tinke "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="palu"/>
                <Content Chars="."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="ni"/>
                <tab/>
                <Content Chars="le"/>
                <tab/>
                <Content Chars="tinke"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="palu"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="you"/>
                <tab/>
                <Content Features="inherit smallcaps" Chars="past"/>
                <tab/>
                <Content Chars="drink"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="milk"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <tab/>
                <Content Chars="You drank milk."/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <Content CParent="Header #1" FontColor="Red" FillShade="100" Chars="Dependent Parts of Speech"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <Content Chars="There are two additional parts of speech that can only appear when they are attached to another word or phrase: prepositions and particles."/>
                <para/>
                <para/>
                <Content Chars="A "/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="preposition"/>
                <Content Chars=" creates a relationship between a noun and other parts of the sentence. Usually, this relationship has to do with location, time, direction, or manner. Prepositions are words like “in,” “at,” “on,” “while,” and so on."/>
                <para/>
                <para/>
                <tab/>
                <Content Chars="Ta-ye ale "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="a"/>
                <Content Chars=" ca-kasa "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="teke"/>
                <Content Chars=" kasa."/>
                <para/>
                <tab/>
                <Content FontSize="10" Chars="ta-ye"/>
                <tab FontSize="10"/>
                <Content FontSize="10" Chars="ale"/>
                <tab FontSize="10"/>
                <Content Font="Times New Roman Bold" FontSize="10" FontColor="Blue" FillShade="100" Chars="a"/>
                <tab FontSize="10"/>
                <Content FontSize="10" Chars="aiki-meta"/>
                <tab FontSize="10"/>
                <Content Font="Times New Roman Bold" FontSize="10" FontColor="Blue" FillShade="100" Chars="teke"/>
                <tab FontSize="10"/>
                <Content FontSize="10" Chars="kasa"/>
                <para/>
                <tab FontSize="10"/>
                <Content FontSize="10" Chars="they (2+)"/>
                <tab FontSize="10"/>
                <Content FontSize="10" Chars="go"/>
                <tab FontSize="10"/>
                <Content Font="Times New Roman Bold" FontSize="10" FontColor="Blue" FillShade="100" Chars="to"/>
                <tab FontSize="10"/>
                <Content FontSize="10" Chars="workplace"/>
                <tab FontSize="10"/>
                <Content Font="Times New Roman Bold" FontSize="10" FontColor="Blue" FillShade="100" Chars="from"/>
                <tab FontSize="10"/>
                <Content FontSize="10" Chars="home"/>
                <para/>
                <tab/>
                <Content Chars="They are going to work from home."/>
                <para/>
                <para/>
                <Content Font="Times New Roman Bold" FontColor="Red" FillShade="100" Chars="Particles"/>
                <Content Chars=" add information and connect phrases.  In Mitaeme, this includes words like “no,” “that,” “and,” as well as possessive and question markers."/>
                <para/>
                <para/>
                <tab/>
                <Content Chars="Yena ye "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="te"/>
                <Content Chars=" auto "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="ke"/>
                <Content Chars=" ni cihuan "/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="ma"/>
                <Content Chars="."/>
                <para/>
                <tab/>
                <Content FontSize="10" Chars="yena "/>
                <tab FontSize="10"/>
                <Content FontSize="10" Chars="ye"/>
                <tab FontSize="10"/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="te"/>
                <tab FontSize="10"/>
                <Content FontSize="10" Chars="auto"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="ke"/>
                <tab/>
                <Content Chars="ni"/>
                <tab/>
                <Content Chars="cihuan"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="ma"/>
                <para/>
                <tab/>
                <Content Chars="that"/>
                <tab/>
                <Content Chars="they"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="’s"/>
                <tab/>
                <Content Chars="car"/>
                <tab/>
                <Content Font="Times New Roman Bold" FontColor="Blue" FillShade="100" Chars="that"/>
                <tab/>
                <Content Chars="you"/>
                <tab/>
                <Content Chars="like"/>
                <tab/>
                <Content Font="Times New Roman Bold" Features="inherit smallcaps" FontColor="Blue" FillShade="100" Chars="question"/>
                <para/>
                <tab/>
                <Content Chars="Is that their car that you like?"/>
                <para/>
                <para/>
            </StoryText>
        </PageObject>
