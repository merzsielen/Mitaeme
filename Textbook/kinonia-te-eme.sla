            <StoryText>
                <DefaultStyle/>
                <Content CParent="Header #1" FontColor="Red" FillShade="100" Chars="Dedications"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para ParagraphEffectOffset="3.6" ParagraphEffectIndent="1" HasDropCap="0" Bullet="0" Numeration="0" NumerationFormat="0" NumerationName="&lt;local block&gt;" NumerationLevel="0" NumerationPrefix="" NumerationSuffix="." NumerationStart="1" NumerationOther="1" NumerationHigher="1"/>
                <para/>
                <para/>
                <para/>
                <para/>
                <Content Chars="This work is dedicated to the fight for transsex liberation around the world."/>
                <para/>
                <para/>
                <Content Chars="Access to healthcare, community, and safety are systematically stripped from transsex individuals by all extant governments. All we have is each other."/>
                <para/>
                <para/>
                <Content Chars="You are my sisters and brothers, my siblings in light. I love you."/>
                <trail/>
            </StoryText>
        </PageObject>
